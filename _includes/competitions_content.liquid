<!-- _includes/competitions_content.liquid -->
<!-- Data-driven competition list, reads from _data/competitions.yml -->
<!-- Gallery data loaded from _data/gallery/competitions/*.yml -->

<div class="competitions-section">

<p>Below is a collection of competitions and awards. Click on any photo to view in full size.</p>
<p>以下是我参与的竞赛和获奖经历。点击照片可查看大图。</p>

<hr />

{% for comp in site.data.competitions %}
  {% if comp.section_title %}
    <h2>{{ comp.section_title }}</h2>
  {% else %}
    {% include competition_card.liquid comp=comp %}
    {% unless forloop.last %}<hr />{% endunless %}
  {% endif %}
{% endfor %}

</div><!-- end competitions-section -->
